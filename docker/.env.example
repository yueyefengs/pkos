# Docker 环境配置文件示例
# 复制此文件为 .env 并根据实际情况修改

# ============================================
# 生产环境 Docker 镜像配置
# ============================================
# Docker 镜像名称，格式: registry/username/image:tag
# 示例:
#   - Docker Hub: yourusername/pkos:latest
#   - GitHub Container Registry: ghcr.io/yourusername/pkos:latest
#   - Aliyun Container Registry: registry.cn-hangzhou.aliyuncs.com/yourusername/pkos:latest
IMAGE_NAME=ghcr.io/yueyefeng11/pkos:latest

# ============================================
# 应用配置 (会覆盖 .env 中的配置)
# ============================================
# Python 环境变量
PYTHONUNBUFFERED=1

# 数据库配置 (Docker 内部网络)
DB_HOST=db
DB_PORT=5432
DB_USER=feishu
DB_PASSWORD=feishu123
DB_NAME=feishu_knowledge

# Redis 配置 (Docker 内部网络)
REDIS_HOST=redis
REDIS_PORT=6379

# 飞书配置 (需要在 .env 中配置或在此处配置)
FEISHU_APP_ID=cli_a9ffc7408e78dcda
FEISHU_APP_SECRET=OgpW6nt5cO2QJ11qAh2jnfi1e8YFsjt8
FEISHU_BOT_NAME=知识助手
FEISHU_ENCRYPT_KEY=xxxxx

# ============================================
# LLM 多模型配置
# ============================================

# 默认使用的 LLM 提供商 (openai | deepseek | glm | claude)
LLM_DEFAULT_PROVIDER=openai

# OpenAI 配置
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# DeepSeek 配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# GLM (智谱) 配置
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4

# Claude 配置
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022
