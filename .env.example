# 飞书应用配置
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=xxxxx
FEISHU_BOT_NAME=知识助手

# 飞书事件接收模式: websocket (推荐) 或 webhook
# websocket: 无需公网IP，配置简单，自动处理签名验证
# webhook: 需要公网IP，需要配置加密密钥
FEISHU_EVENT_MODE=websocket

# 飞书加密密钥 (仅 webhook 模式需要)
# 在飞书开放平台 -> 事件订阅 -> 加密密钥 中获取
FEISHU_ENCRYPT_KEY=xxxxx

# 飞书多维表格配置
FEISHU_BITABLE_TOKEN=xxxxx
FEISHU_BITABLE_TABLE_ID=xxxxx

# 数据库配置
DB_HOST=db
DB_PORT=5432
DB_USER=feishu
DB_PASSWORD=feishu123
DB_NAME=feishu_knowledge

# Redis配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# 服务配置
HOST=0.0.0.0
PORT=8080

# 抖音配置
DOUYIN_COOKIES_FILE=douyin_cookies.txt

# ============================================
# LLM 多模型配置
# ============================================

# 默认使用的 LLM 提供商 (openai | deepseek | glm | claude)
LLM_DEFAULT_PROVIDER=openai

# OpenAI 配置
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# DeepSeek 配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# GLM (智谱) 配置
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4

# Claude 配置
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Telegram Bot Configuration
# 获取方式: 在Telegram中找到@BotFather, 发送/newbot创建bot并获取token
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username

# Redis Configuration (for session management)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
