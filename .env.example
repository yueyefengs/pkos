# ============================================
# Telegram Bot 配置
# ============================================
# 获取方式: 在Telegram中找到@BotFather, 发送/newbot创建bot并获取token
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username

# ============================================
# 数据库配置
# ============================================
# 本地运行使用localhost，Docker使用db
DB_HOST=localhost
DB_PORT=5432
DB_USER=pkos
DB_PASSWORD=pkos123
DB_NAME=pkos_knowledge

# ============================================
# Redis配置
# ============================================
# 本地运行使用localhost，Docker使用redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# 服务配置
# ============================================
HOST=0.0.0.0
PORT=8080

# ============================================
# 视频下载配置
# ============================================
# 抖音cookies文件路径 (相对于项目根目录)
DOUYIN_COOKIES_FILE=douyin_cookies.txt

# ============================================
# LLM 多模型配置
# ============================================

# 默认使用的 LLM 提供商 (openai | deepseek | glm | claude)
LLM_DEFAULT_PROVIDER=openai

# OpenAI 配置
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# DeepSeek 配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# GLM (智谱) 配置
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4

# Claude 配置
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022
